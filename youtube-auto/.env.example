# 1. Google Gemini (Free): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Pexels (Free): https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# 3. Pixabay (Free): https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_api_key_here
